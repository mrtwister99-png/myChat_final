+    const messages = tokens.map((token) => ({
+      to: token,
+      sound: 'default',
+      title: String(title || 'Nova zprava').slice(0, 120),
+      body: String(body || '').slice(0, 240),
+      data: data || {},
+      channelId: 'default',
+    }));
+
