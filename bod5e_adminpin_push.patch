diff --git a/src/screens/AdminPin.js b/src/screens/AdminPin.js
index 0000000..1111111 100644
--- a/src/screens/AdminPin.js
+++ b/src/screens/AdminPin.js
@@ -20,6 +20,18 @@ const AdminPin = ({ navigation }) => {
   useEffect(() => {
     socket.emit('state:get');
   }, []);
 
+  useEffect(() => {
+    const registerAdminPushToken = () => {
+      const pushToken = globalThis.CUSIIK_EXPO_PUSH_TOKEN;
+      if (pushToken && socket.connected) {
+        socket.emit('notifications:registerToken', {
+          token: pushToken,
+          role: 'admin',
+        });
+      }
+    };
+    registerAdminPushToken();
+    socket.on('connect', registerAdminPushToken);
+    return () => socket.off('connect', registerAdminPushToken);
+  }, []);
+
   return null;
 };

